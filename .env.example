# Discord Bot Token (required)
# Create app at https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application (Client) ID — used for registering slash commands
CLIENT_ID=your_application_id_here

# Optional: Guild ID for fast slash-command registration in one server during development
# If set, commands are registered to this guild only (instant). If omitted, global (can take up to 1 hour).
# GUILD_ID=your_guild_id_here

# Optional: Log level — error | warn | info | debug
# LOG_LEVEL=info
